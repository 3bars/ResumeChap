# Dependencies
node_modules/
yarn.lock

# Python virtual env (created by the launcher)
.venv/
__pycache__/
*.pyc

# Build output
dist/
build/
*.zip

# Ship the pre-built frontend so end users only need Python to run the app.
!app/frontend/dist/
!app/frontend/dist/**

# Local runtime data (SQLite DB, AI settings with API keys) — never commit.
*.db
ai_settings.json

# Environment / secrets
.env
.env.local

# Editor / OS files
.vscode/
.idea/
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
